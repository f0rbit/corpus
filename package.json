{
	"name": "@f0rbit/corpus",
	"version": "0.8.0",
	"description": "A functional snapshotting library for TypeScript with versioned data storage, lineage tracking, and multiple backend support",
	"keywords": [
		"data-store",
		"lineage",
		"snapshot",
		"typescript",
		"versioning"
	],
	"homepage": "https://github.com/f0rbit/corpus#readme",
	"bugs": {
		"url": "https://github.com/f0rbit/corpus/issues"
	},
	"license": "MIT",
	"author": "f0rbit",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/f0rbit/corpus.git"
	},
	"bin": {
		"corpus": "./dist/cli/index.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		},
		"./file": {
			"types": "./dist/file.d.ts",
			"import": "./dist/file.js",
			"require": "./dist/file.js"
		},
		"./cloudflare": {
			"types": "./dist/cloudflare.d.ts",
			"import": "./dist/cloudflare.js",
			"require": "./dist/cloudflare.js"
		},
		"./remote": {
			"types": "./dist/remote.d.ts",
			"import": "./dist/remote.js",
			"require": "./dist/remote.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js",
			"require": "./dist/types.js"
		},
		"./schema": {
			"types": "./dist/schema.d.ts",
			"import": "./dist/schema.js",
			"require": "./dist/schema.js"
		},
		"./testing": {
			"types": "./dist/testing/index.d.ts",
			"import": "./dist/testing/index.js",
			"require": "./dist/testing/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"build:llm": "node scripts/generate-llm-docs.js",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build",
		"docs:dev": "cd docs && bun run dev",
		"docs:build": "npm run build:llm && cd docs && bun run build",
		"docs:preview": "cd docs && bun run preview",
		"lint": "oxlint . && eslint .",
		"lint:fix": "oxlint --fix . && eslint --fix .",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check ."
	},
	"dependencies": {
		"@traversable/zod-test": "^0.0.28",
		"drizzle-orm": "^0.44.7",
		"fast-check": "^4.7.0"
	},
	"devDependencies": {
		"@f0rbit/lint": "0.3.0",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5",
		"zod": "^3"
	},
	"corpus": {
		"testing": "./dist/testing/register.js"
	}
}
